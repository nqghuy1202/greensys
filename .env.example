# Oracle Database
DB_USER=
DB_PASSWORD=
DB_CONNECTION_STRING=localhost:1521/XEPDB1

# Oracle Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1

# Node.js Server
PORT=3000
NODE_ENV=development

# Oracle APEX
APEX_BASE_URL=http://localhost:8080/ords

# CQN (Continuous Query Notification)
CQN_HOST=localhost
CQN_PORT=3001
