# Oracle Database (Server A)
DB_USER=DEV24
DB_PASSWORD=
DB_CONNECTION_STRING=192.168.1.10/FREEPDB1

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1

# Node.js Socket.io server port (APEX clients connect here)
PORT=3140
NODE_ENV=production

# CORS — URL(s) that APEX browsers use to reach APEX (comma-separated)
APEX_ORIGINS=http://192.168.1.10:8080

# CQN callback — Server B's IP and port that Oracle DB will call back on
# Firewall required: Server A → Server B:CQN_PORT (TCP)
CQN_HOST=192.168.1.20
CQN_PORT=3141
